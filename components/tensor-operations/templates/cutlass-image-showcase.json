{
  "kind": "blacknode.workflow",
  "schema_version": 1,
  "name": "CUTLASS Image Showcase",
  "saved_at": "2026-05-31T00:00:00",
  "entrypoint": {
    "node_id": "out",
    "port": "image"
  },
  "metadata": {
    "template": true,
    "description": "Run a convolution on your image as a real CUTLASS GEMM (im2col) on the NVIDIA GPU. Set an image on LoadImage (browse or paste a path), pick a filter on the CUTLASS node (edge / emboss / sharpen / blur), then cook OutputImage. First cook is ~15-20s (starts the Docker CUTLASS worker); after that it is instant. Requires Docker running and the blacknode-cutlass image.",
    "color": "#76b900"
  },
  "node_meta": {
    "load": {
      "id": "load",
      "type": "LoadImage",
      "params": { "source": "", "max_size": 512 },
      "pos": [80, 200],
      "inputs": ["source", "max_size"],
      "outputs": ["image", "width", "height", "report"],
      "input_types": { "source": "Image", "max_size": "Int" },
      "output_types": { "image": "Image", "width": "Int", "height": "Int", "report": "Dict" },
      "input_defaults": { "source": "", "max_size": 512 }
    },
    "cutlass": {
      "id": "cutlass",
      "type": "CUTLASS",
      "params": { "op": "conv2d", "filter": "emboss", "size": 512, "seed": 0 },
      "pos": [440, 220],
      "inputs": ["input", "op", "filter", "size", "seed"],
      "outputs": ["output", "result", "gpu_ms", "tflops", "device", "report"],
      "input_types": { "input": "Any", "op": "Text", "filter": "Text", "size": "Int", "seed": "Int" },
      "output_types": { "output": "Any", "result": "Dict", "gpu_ms": "Float", "tflops": "Float", "device": "Text", "report": "Dict" },
      "input_defaults": { "op": "auto", "filter": "sharpen", "size": 512, "seed": 0 }
    },
    "out": {
      "id": "out",
      "type": "OutputImage",
      "params": {},
      "pos": [820, 240],
      "inputs": ["image"],
      "outputs": ["image"],
      "input_types": { "image": "Image" },
      "output_types": { "image": "Image" },
      "input_defaults": {}
    }
  },
  "edges": [
    { "from": "load", "from_port": "image", "to": "cutlass", "to_port": "input" },
    { "from": "cutlass", "from_port": "output", "to": "out", "to_port": "image" }
  ]
}
